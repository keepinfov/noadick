# Telegram bot token from @BotFather (required)
BOT_TOKEN=123456:your-token-here

# Comma-separated Telegram user IDs allowed into the /admin panel
ADMIN_IDS=

# Path to the SQLite database file (default: ./data/bot.db)
DB_PATH=./data/bot.db

# Timezone used for the daily /dick reset (default: Europe/Moscow)
TZ=Europe/Moscow

# Optional outbound proxy for the Telegram API (e.g. socks5://user:pass@host:port)
PROXY=
